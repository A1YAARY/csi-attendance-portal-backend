{
  "scripts": {
    "run_next_migration": "knex migrate:up --env api_write --migrations-directory src/models/migrations",
    "undo_last_migration": "knex migrate:down --env api_write --migrations-directory src/models/migrations",
    "create_migration": "knex migrate:make --migrations-directory src/models/migrations",
    "dev": "nodemon bin/www",
    "start": "node bin/www"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "errors": "^0.3.0",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "express-jwt": "^8.5.1",
    "joi": "^18.1.1",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "path": "^0.12.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
